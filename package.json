{
  "name": "oremus-web-search",
  "version": "0.1.6",
  "description": "CLI for Oremus web search, extraction, and VPN rotation over the REST API",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Oremus-Labs/web-search-mcp.git"
  },
  "homepage": "https://github.com/Oremus-Labs/web-search-mcp",
  "bugs": {
    "url": "https://github.com/Oremus-Labs/web-search-mcp/issues"
  },
  "bin": {
    "oremus-web-search": "dist/index.js",
    "web-search": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "clean": "shx rm -rf dist",
    "dev": "tsx src/index.ts",
    "prepack": "npm run clean && npm run build",
    "test": "node --import tsx --test test/**/*.test.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.17.2",
    "shx": "^0.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
