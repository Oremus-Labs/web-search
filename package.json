{
  "name": "@oremus-labs/web-search-mcp",
  "version": "0.1.0",
  "description": "MCP server that combines SearXNG web search with Trafilatura extraction",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Oremus-Labs/web-search-mcp.git"
  },
  "homepage": "https://github.com/Oremus-Labs/web-search-mcp",
  "bugs": {
    "url": "https://github.com/Oremus-Labs/web-search-mcp/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "web-search-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "clean": "shx rm -rf dist",
    "dev": "tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepack": "npm run clean && npm run build",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "shx": "^0.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
