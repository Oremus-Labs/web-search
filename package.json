{
  "name": "@oremus-labs/web-search",
  "version": "0.1.7",
  "description": "CLI for web search, extraction, and proxy rotation over a REST API",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Oremus-Labs/web-search.git"
  },
  "homepage": "https://github.com/Oremus-Labs/web-search",
  "bugs": {
    "url": "https://github.com/Oremus-Labs/web-search/issues"
  },
  "bin": {
    "web-search": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "clean": "shx rm -rf dist",
    "dev": "tsx src/index.ts",
    "prepack": "npm run clean && npm run build",
    "test": "node --import tsx --test test/**/*.test.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "shx": "^0.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
